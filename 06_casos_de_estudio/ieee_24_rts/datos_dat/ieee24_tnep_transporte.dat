	let Pd[i]:= Pd[i]/Sbase;
	let Pgmax[i]:= Pgmax[i]/Sbase;
	let Pgmin[i]:= Pgmin[i]/Sbase;
}

#Inicialización de variables y normalizacion de datos del sistema en por unidad en el conjunto de ramales
