#inicializar variables y normalizar los datos del sistema para el conjunto de barras

for {i in OB} {								# let asigna un valor preestablecido a los parametros
  let Pd[i] := Pd[i]/Sbase;        			# colocar en pu.
  let Qd[i] := Qd[i]/Sbase;        			# colocar en pu.
  let Qgmax[i] := Qgmax[i]/Sbase;			  # colocar en pu.
  let Qgmin[i] := Qgmin[i]/Sbase;			  # colocar en pu.
  let V[i]  := V0[i];              			# inicializando las variables de voltaje
  let th[i] := th0[i]*3.14159/180; 			# inicializando las variables de angulo
  let Pg[i] := Pg0[i]/Sbase;       			# inicializando las variables de potencia activa
  let Qg[i] := Qg0[i]/Sbase;       			# inicializando las variables de potencia reactiva
}
#inicializar variables y normalizar datos para el conjunto de lineas

for {(k,i,j) in OL} {
  let fi[k,i,j] := fi[k,i,j]*3.14159/180; 	# convertir en rad.
  let Smax[k,i,j] := Smax[k,i,j]/Sbase;    	# convertir en pu. 
  if (Tr[k,i,j] == 0) then {				        # si es un transformador, entonces:
    let a[k,i,j] := 1;						          # asignar a=1, es una linea
  } else {									                # si es un transformador asignale 1/a
    let a[k,i,j] := 1/a[k,i,j];             # a=1/n, revisar el modelo de transformador
	  let bshl[k,i,j]:=0;					            # es un dato del .dat no hace falta
  }
  let bshl[k,i,j] := bshl[k,i,j]/2;			    #asegurarse de tener B/2
  let g[k,i,j] :=  r[k,i,j]/(r[k,i,j]^2 + x[k,i,j]^2); # calculo de la conductancia
  let b[k,i,j] := -x[k,i,j]/(r[k,i,j]^2 + x[k,i,j]^2); # calculo de la susceptancia

  let Pde[k,i,j] := 0.0; 					# inicializando las variables
  let Qde[k,i,j] := 0.0; 					# inicializando las variables
  let Ppa[k,i,j] := 0.0; 					# inicializando las variables
  let Qpa[k,i,j] := 0.0; 					# inicializando las variablesu
}

#fijar la magnitud de tension en las barras de generaci�n
fix {i in OB : Tb[i] == 3 } V[i] := Vg[i];
fix {i in OB : Tb[i] == 2 } V[i] := Vg[i];
#fix {i in OB : Tb[i] == 2 || Tb[i] == 3} V[i] := V0[i];

# fijar la alimentacion de potencia activa de las barras de carga y generaci�n
fix {i in OB : Tb[i] == 2} Pg[i] := Pg0[i]/Sbase;
fix {i in OB : Tb[i] == 0} Pg[i] := 0.0;

# fijar la alimentacion de potencia reactiva de las barras de carga y generaci�n
fix {i in OB : Tb[i] == 0} Qg[i] := 0.0;
	
# fijar el angulo de fase en la referencia
fix {i in OB : Tb[i] == 3} th[i] := th0[i]*3.14159/180;
